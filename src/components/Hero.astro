---

<div class="hero">
  <div class="stage" style={`width:${W}px; height:${H}px;`}>

    <!-- LAYER 1: base image (placeholder) -->
    <div class="base-img"></div>

    <!-- LAYER 2: one clipped media container per cell, hidden until hover -->
{hotspots.map((h) => (
      <div class="cell-media-wrap" style={`transform: translate(${h.dx}px, ${h.dy}px);`}>
        <div class="cell-media" id={`media-${h.id}`}
             style={`clip-path: path('${h.path}'); -webkit-clip-path: path('${h.path}');`}>
          <div class="cell-media-inner" style={`transform: translate(${-h.dx}px, ${-h.dy}px);`}></div>
        </div>
      </div>
    ))}

    <!-- LAYER 3: SVG outlines (the glow/border) + click targets -->
  <svg class="outlines" viewBox={`0 0 ${W} ${H}`} xmlns="http://www.w3.org/2000/svg">
        {hotspots.map((h) => (
          <g class="hotspot" transform={`translate(${h.dx} ${h.dy})`}
            data-id={h.id} data-label={h.label} data-media={JSON.stringify(h.media)}>
            <path d={h.path} class="outline-shape" />
          </g>
        ))}
      </svg>
  </div>

  <!-- LAYER 4: text-only side panel -->
  <aside class="hero-panel">
    <p class="panel-hint">// hover a cell</p>
    <p id="panel-label" class="panel-label">Macrophage field</p>
    <p id="panel-blurb" class="panel-blurb">Hover a cell to inspect · click a marker to swap.</p>
  </aside>
</div>

<style>
  .hero { display:flex; gap:2ch; flex-wrap:wrap; align-items:flex-start;
          border: var(--border-thickness) solid var(--fg); margin:1.5rem 0; 
          padding:1ch; justify-content:center; }
  .stage { position:relative; flex:none; overflow:hidden;}
  .base-img { position:absolute; inset:0;
              background:url('/hero/composite-field.jpg') no-repeat center;
              background-size:cover; }
  /* clipped media — fills the stage, but clip-path shows only the cell shape */
  .cell-media { position:absolute; inset:0; opacity:0; transition:opacity .25s ease;
                pointer-events:none; }
  .cell-media.show { opacity:1; }
.cell-media-inner { position:absolute; inset:0; }
.cell-media-inner img, .cell-media-inner video { width:700px; height:420px; object-fit:fill; display:block; }

  /* SVG outline layer sits on top, but only the paths catch the mouse */
  .outlines { position:absolute; inset:0; width:100%; height:100%; }
  .outline-shape {
    fill: transparent; stroke: var(--accent); stroke-width:2; opacity:0.4;
    transition: opacity .2s, stroke-width .2s, filter .2s; cursor:pointer;
  }
  /* glow on hover-in; settles to thin border via the .filled class JS adds */
  .hotspot:hover .outline-shape {
    opacity:1; stroke-width:3; filter: drop-shadow(0 0 6px var(--accent));
  }
  .hotspot.filled .outline-shape {
    stroke-width:1.5; filter:none; opacity:0.9;  /* settled thin border */
  }

  .hero-panel { flex:1; min-width:200px; padding:0.5rem 1ch; }
  .panel-hint { color:var(--fg-alt); font-size:0.7rem; text-transform:uppercase; letter-spacing:0.06em; margin:0 0 0.5rem; }
  .panel-label { font-weight:500; margin:0 0 0.4rem; }
  .panel-blurb { color:var(--fg-alt); font-size:0.85rem; margin:0 0 0.6rem; }
  .panel-thumbs { display:flex; gap:0.5ch; flex-wrap:wrap; }
  .thumb { font-size:0.7rem; padding:0.1rem 0.6ch; cursor:pointer; font-family:inherit;
           border:1px solid var(--fg-alt); color:var(--fg-alt); background:transparent; }
  .thumb.active { border-color:var(--accent); color:var(--accent); }
</style>

<script>
  const label = document.getElementById("panel-label");
  const blurb = document.getElementById("panel-blurb");

  function makeMedia(item) {
    if (item.type === "video") {
      const v = document.createElement("video");
      v.src = item.src; v.muted = true; v.loop = true;
      v.autoplay = true; v.playsInline = true;
      return v;
    }
    const img = document.createElement("img");
    img.src = item.src; img.alt = item.label;
    return img;
  }

  function activateCell(hotspot) {
    let media;
    try { media = JSON.parse(hotspot.getAttribute("data-media")); } catch { return; }
    if (!media?.length) return;

    const id = hotspot.getAttribute("data-id");
    const container = document.getElementById("media-" + id);

    // pick a random media item from this cell's set
    const pick = media[Math.floor(Math.random() * media.length)];

    container.replaceChildren(makeMedia(pick));
    container.classList.add("show");
    hotspot.classList.add("filled");

    label.textContent = hotspot.getAttribute("data-label");
    blurb.textContent = pick.label;   // name the marker/video currently shown
  }

  function clearCell(hotspot) {
    const id = hotspot.getAttribute("data-id");
    const container = document.querySelector(`#media-${id} .cell-media-inner`);    container.replaceChildren();       // stop video, free it
    hotspot.classList.remove("filled");
  }

  document.querySelectorAll(".hotspot").forEach((el) => {
    el.addEventListener("mouseenter", () => activateCell(el));
    el.addEventListener("mouseleave", () => clearCell(el));
  });
</script>