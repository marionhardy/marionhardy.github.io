---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("writing");
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.date.toLocaleDateString("en-US", { year:"numeric", month:"long", day:"numeric" });
---

<Base title={`mhy — ${post.data.title}`}>
  <a href="/writing" style="color:var(--fg-alt); font-size:0.85rem;">← writing</a>

  <article class="prose" style="max-width:70ch;">
    <h1 style="margin-bottom:0.25rem;">{post.data.title}</h1>
    <p style="color:var(--fg-alt); font-size:0.85rem; margin:0 0 2rem;">
      {dateStr}{post.data.tags && ` · ${post.data.tags.join(", ")}`}
    </p>
    <Content />
  </article>
</Base>